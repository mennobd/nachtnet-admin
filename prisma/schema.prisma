generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  ORG_ADMIN
  EDITOR
  VIEWER
}

enum RouteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Organization {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[] @relation("PrimaryOrganizationUsers")

  accesses  UserOrganizationAccess[]
}

model User {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  passwordHash   String
  role           UserRole     @default(EDITOR)
  isActive       Boolean      @default(true)

  organizationId String?
  organization   Organization? @relation("PrimaryOrganizationUsers", fields: [organizationId], references: [id])

  organizationAccesses UserOrganizationAccess[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  auditLogs      AuditLog[]
}
model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

model Route {
  id              String         @id @default(cuid())
  routeCode       String         @unique
  title           String
  lineNumber      String
  direction       String
  depot           String
  status          RouteStatus    @default(DRAFT)
  notes           String?

  files           RouteFile[]
  manifestEntries ManifestEntry[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model RouteFile {
  id              String          @id @default(cuid())
  routeId         String
  route           Route           @relation(fields: [routeId], references: [id])

  fileName        String
  storageKey      String?
  checksum        String
  version         String

  manifestEntries ManifestEntry[]

  createdAt       DateTime        @default(now())
}

model ManifestEntry {
  id            String    @id @default(cuid())

  routeId       String
  route         Route     @relation(fields: [routeId], references: [id])

  fileId        String
  file          RouteFile @relation(fields: [fileId], references: [id])

  packageName   String
  type          String
  version       String

  isPublished   Boolean   @default(false)
  activeFrom    DateTime?
  activeUntil   DateTime?
  priority      Int       @default(100)
  notes         String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model UserOrganizationAccess {
  id             String @id @default(cuid())
  userId         String
  organizationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}
