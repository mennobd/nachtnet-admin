generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EDITOR
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum RouteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Route {
  id          String      @id @default(cuid())
  routeCode   String      @unique
  title       String
  lineNumber  String
  direction   String
  depot       String
  status      RouteStatus @default(DRAFT)
  notes       String?

  files            RouteFile[]
  manifestEntries  ManifestEntry[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model RouteFile {
  id          String   @id @default(cuid())
  routeId     String
  route       Route    @relation(fields: [routeId], references: [id])

  fileName    String
  storageKey  String?
  checksum    String
  version     String

  manifestEntries ManifestEntry[]

  createdAt   DateTime @default(now())
}

model ManifestEntry {
  id          String   @id @default(cuid())

  routeId     String
  route       Route    @relation(fields: [routeId], references: [id])

  fileId      String
  file        RouteFile @relation(fields: [fileId], references: [id])

  packageName String
  type        String
  version     String
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
}
