generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EDITOR
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum RouteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Route {
  id          String      @id @default(cuid())
  routeCode   String      @unique
  title       String
  lineNumber  String
  direction   String
  depot       String
  status      RouteStatus @default(DRAFT)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}
