# PostgreSQL database connection URL
DATABASE_URL=

# Secret used to sign session JWTs — must be at least 32 characters
# Generate with: btoa(String.fromCharCode(...crypto.getRandomValues(new Uint8Array(32))))
SESSION_SECRET=

# Base URL of the application, no trailing slash (e.g. https://yourdomain.com)
APP_BASE_URL=

# S3-compatible bucket name for GPX file storage
BUCKET_NAME=

# S3-compatible bucket region
BUCKET_REGION=

# S3-compatible endpoint URL
BUCKET_ENDPOINT=

# S3 access key ID
AWS_ACCESS_KEY_ID=

# S3 secret access key
AWS_SECRET_ACCESS_KEY=

# Initial admin account created by the seed script
ADMIN_EMAIL=

# Initial admin password created by the seed script
ADMIN_PASSWORD=
